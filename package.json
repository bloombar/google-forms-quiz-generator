{
  "name": "google-forms-quiz-tool",
  "version": "1.0.0",
  "description": "CLI tool to round-trip Google Forms quizzes to and from a simple text format.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "quiz-tool": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "google-forms",
    "quiz",
    "cli",
    "yaml"
  ],
  "license": "MIT",
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "dotenv": "^16.6.1",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "js-yaml": "^4.1.0",
    "yargs": "^18.0.0"
  },
  "overrides": {
    "google-auth-library": "^10.7.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.16.0",
    "@types/yargs": "^17.0.33",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.28.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
